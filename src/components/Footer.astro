---
import { SITE } from "../config/site";
---

<footer>
  <div class="inner">
    <p>© {new Date().getFullYear()} {SITE.name}. All rights reserved.</p>
    <div class="social">
      <a
        href="https://www.facebook.com/people/100-%CE%92%CE%B9%CE%BF%CE%BB%CE%BF%CE%B3%CE%B9%CE%BA%CF%8C%CF%82-%CE%A7%CF%85%CE%BC%CF%8C%CF%82-%CE%A1%CF%8C%CE%B4%CE%B9%CE%9C%CE%B5-%CE%BA%CE%B1%CF%84%CE%B1%CE%B3%CF%89%CE%B3%CE%AE-%CE%9A%CF%81%CE%B5%CE%BC%CE%B1%CF%83%CF%84%CF%8C%CF%82-%CE%95%CF%8D%CE%B2%CE%BF%CE%B9%CE%B1%CF%82/100086287311160/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Facebook"
        title="Facebook"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" aria-hidden="true">
          <circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="1.8" />
          <!-- stylized 'f' -->
          <rect x="11" y="6" width="2" height="12" fill="currentColor" />
          <rect x="10" y="6" width="6" height="2" fill="currentColor" />
          <rect x="10" y="11" width="4" height="2" fill="currentColor" />
        </svg>
      </a>
      <a
        href="https://www.instagram.com/rodi_xymos_kremastos_evia/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Instagram"
        title="Instagram"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <rect x="3" y="3" width="18" height="18" rx="4" ry="4" stroke="currentColor" stroke-width="1.8" />
          <circle cx="12" cy="12" r="5" stroke="currentColor" stroke-width="1.8" />
          <circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" />
        </svg>
      </a>
    </div>
  </div>
</footer>

<style lang="scss">
  $padding: 2rem;

  footer {
    color: var(--muted);

    .inner {
      max-width: 1100px;
      margin: 0 auto;
      padding: $padding;
      width: calc(100% - 2 * $padding);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: $padding;
    }

    p {
      margin: 0;
    }

    .social {
      display: inline-flex;
      gap: $padding * 0.5;
      align-items: center;

      a {
        color: var(--muted);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2.25rem;
        height: 2.25rem;
        border-radius: 9999px;
        transition: color 150ms ease, transform 150ms ease, background-color 150ms ease;
        text-decoration: none;

        &:hover {
          color: var(--text);
          transform: translateY(-1px);
          background-color: rgba(255, 255, 255, 0.06);
        }

        &:focus-visible {
          outline: 2px solid var(--border);
          outline-offset: 2px;
        }
      }

      a[aria-label="Facebook"]:hover { color: #1877f2; }
      a[aria-label="Instagram"]:hover { color: #e4405f; }
    }
  }
</style>
